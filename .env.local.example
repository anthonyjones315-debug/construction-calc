# Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key

# Auth.js — In Vercel set NEXTAUTH_URL and AUTH_URL to https://proconstructioncalc.com
AUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=https://proconstructioncalc.com
AUTH_URL=https://proconstructioncalc.com
AUTH_TRUST_HOST=true
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Supavisor transaction pooler (port 6543) for runtime / server actions / Drizzle app traffic
SUPABASE_DB_TRANSACTION_URL=
# Supavisor session pooler (port 5432) for drizzle-kit push / migrations only
SUPABASE_DB_SESSION_URL=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-X2G03GC8GL

# PostHog (product analytics — client + server)
# Get your key from https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# AdSense
NEXT_PUBLIC_ADSENSE_ID=ca-pub-9267885260213830

# Amazon Associates
NEXT_PUBLIC_AMAZON_TAG=buildcalcpro-20

# Sentry (client + server error tracking + Calculator Audit)
# Set in Vercel for production; hideSourceMaps: true in next.config keeps IP hidden while Sentry still receives maps.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=anthony-jones
SENTRY_PROJECT=javascript-nextjs
# Development: forward events to Spotlight (npx @spotlightjs/spotlight)
NEXT_PUBLIC_SENTRY_SPOTLIGHT=0
SENTRY_SPOTLIGHT=0

# Resend (CRM Email Engine / lead funnel — Phase 2)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Pro Construction Calc <estimates@your-domain.com>
RESEND_LEAD_BCC=your-professional-email@example.com

# Stripe (donations – backend only, feature-flagged)
# Do NOT enable in production until donation flows are fully reviewed.
STRIPE_DONATIONS_ENABLED="false"
STRIPE_SECRET_KEY="sk_test_replaceme"
STRIPE_WEBHOOK_SECRET_DONATIONS="whsec_replaceme"
