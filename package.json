{
  "name": "proconstructioncalc",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm run check:strict-types && npm run check:syntax-guards && next build",
    "start": "next start",
    "lint": "npm run check:root-types && npm run lint:src",
    "test": "vitest run",
    "lint:src": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "check:root-types": "node scripts/enforce-types-only.mjs",
    "check:strict-types": "npm run check:root-types && npm run typecheck && npm run lint:src",
    "check:syntax-guards": "node scripts/check-structural-syntax.mjs",
    "build:calcs": "tsc -p tsconfig.calcs.json",
    "db:push": "drizzle-kit push",
    "check-calculations": "npm run build:calcs && node scripts/rewrite-calcs-paths.mjs && node scripts/check-calculations.mjs",
    "check-colors": "node scripts/check-color-contrast.mjs",
    "check-calcs": "npm run check-calculations && npm run check-colors",
    "benchmark:frontend": "node scripts/benchmark-frontend-metrics.mjs",
    "supabase:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/lib/supabase/types.gen.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=no-auth --grep @smoke",
    "test:e2e:smoke:ci": "playwright test --project=no-auth --grep @smoke --workers=1 --reporter=list",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "discover-features": "ts-node scripts/discover-features.ts",
    "generate-tests": "node scripts/generate-tests.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clerk/nextjs": "^7.0.6",
    "@next/third-parties": "^16.2.1",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/nextjs": "^10.43.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-orm": "^0.44.5",
    "immer": "^11.1.4",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "postcss": "^8.5.8",
    "postgres": "^3.4.7",
    "posthog-js": "^1.360.2",
    "posthog-node": "^5.28.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-google-autocomplete": "^2.7.5",
    "react-markdown": "^10.1.0",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "resend": "^6.9.3",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.6",
    "@playwright/test": "^1.58.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "puppeteer": "^24.7.1",
    "supabase": "^2.83.0",
    "vitest": "^1.6.0",
    "ts-node": "^10.9.2"
  }
}
