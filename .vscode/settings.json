{
  // Auto-format on save using Prettier (install "Prettier" extension)
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // Treat .jsx files as React
  "files.associations": {
    "*.jsx": "javascriptreact"
  },

  // Show a line at 100 chars so lines don't get too long
  "editor.rulers": [100],

  // Inline variable values while debugging (shows values next to code)
  "editor.inlineSuggest.enabled": true,
  "debug.inlineValues": "on",

  // Auto-save when you switch away from VS Code
  "files.autoSave": "onFocusChange",

  // Show npm scripts in the Explorer sidebar for quick access
  "npm.enableRunFromFolder": true,

  // Hide noise from Explorer
  "files.exclude": {
    "node_modules": true,
    "dist": true
  }
}
